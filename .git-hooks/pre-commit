#!/usr/bin/env bash
set -euo pipefail

# FindTheCoffee Pre-Commit Hook
# Runs critical checks before allowing commits
# 
# Checks performed:
# 1. Backend tests (pytest - quick mode)
# 2. Frontend lint (deno lint)
# 3. Frontend format check (deno fmt --check)
# 4. TypeScript type check (deno check)
# 5. Python type check (basedpyright)

echo "🔍 Running pre-commit checks..."
echo ""

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

FAILED=0

# 1. Backend Tests (quick mode)
echo "🧪 Running backend tests..."
if mise run test:quiet; then
    echo -e "${GREEN}✓${NC} Backend tests passed"
else
    echo -e "${RED}✗${NC} Backend tests failed"
    FAILED=1
fi
echo ""

# 2. Frontend Lint
echo "📏 Linting frontend code..."
if mise run js:lint; then
    echo -e "${GREEN}✓${NC} Frontend lint passed"
else
    echo -e "${RED}✗${NC} Frontend lint failed"
    echo "   Run ${YELLOW}mise run js:lint${NC} to see details"
    FAILED=1
fi
echo ""

# 3. Frontend Format Check
echo "📐 Checking frontend formatting..."
if deno fmt frontend/src/ --check >/dev/null 2>&1; then
    echo -e "${GREEN}✓${NC} Frontend format passed"
else
    echo -e "${YELLOW}!${NC} Frontend format needs fixes"
    echo "   Run ${YELLOW}mise run js:format${NC} to auto-fix"
    FAILED=1
fi
echo ""

# 4. TypeScript Type Check
echo "🔍 Type checking frontend..."
if mise run ts:check; then
    echo -e "${GREEN}✓${NC} Frontend types passed"
else
    echo -e "${RED}✗${NC} Frontend types failed"
    FAILED=1
fi
echo ""

# 5. Python Type Check (if basedpyright is available)
echo "🐍 Type checking backend..."
if command -v .venv/bin/basedpyright &> /dev/null; then
    if .venv/bin/basedpyright --ignoreexternal backend/ 2>&1 | grep -q "error"; then
        echo -e "${RED}✗${NC} Backend types have errors"
        echo "   Run ${YELLOW}.venv/bin/basedpyright backend/${NC} to see details"
        FAILED=1
    else
        echo -e "${GREEN}✓${NC} Backend types passed"
    fi
else
    echo -e "${YELLOW}⊘${NC} Backend types skipped (basedpyright not installed)"
fi
echo ""

# Summary
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
if [ $FAILED -eq 0 ]; then
    echo -e "${GREEN}✅ All pre-commit checks passed!${NC}"
    exit 0
else
    echo -e "${RED}❌ Some pre-commit checks failed${NC}"
    echo ""
    echo "Fix the issues above and try again."
    echo "Tip: Run ${YELLOW}mise run js:format${NC} to auto-fix formatting."
    exit 1
fi
